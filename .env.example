PORT=4021

# x402 — Base Sepolia testnet defaults (free, no signup)
NETWORK=eip155:84532
FACILITATOR_URL=https://x402.org/facilitator
# REQUIRED — your seller wallet address. The server refuses to start if unset
# or the zero address. On testnet, any Sepolia wallet you control is fine.
PAY_TO=

# Optional: a custom RPC for ENS resolution (/passport/bind anchor_kind=ens)
# and blockhash-seeded sortition draws (/random/sortition). Falls back to
# viem's public default if unset.
RPC_URL=

# HMAC key for server-issued attestations across /passport, /escrow,
# /agora/auction. Use a per-process random secret in dev; set to a stable
# 16+ char value in prod so attestations issued before a restart still verify.
SIGNING_SECRET=

# PostHog (optional — analytics is a no-op when key is unset)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# /help operator metadata
OPERATOR_CONTACT=ops@x402.aegent.dev
STATUS_PAGE_URL=
TOS_URL=

# Public base URL for absolute /help URLs (leave unset for relative URLs)
PUBLIC_BASE_URL=

# Buyer demo only
BUYER_PRIVATE_KEY=
X402_URL=http://localhost:4021
